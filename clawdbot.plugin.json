{
  "id": "aeo-monitor",
  "name": "AEO Monitor",
  "version": "0.1.0",
  "description": "Daily AEO (Answer Engine Optimization) visibility scorecard for Nomie",
  "author": "clawdbot",
  "main": "index.ts",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "runHourUtc": {"type": "number", "default": 5, "description": "Hour (UTC) to run daily. 9am GST = 5 UTC."},
      "runMinuteUtc": {"type": "number", "default": 0, "description": "Minute (UTC) to run daily."},
      "logDir": {"type": "string", "default": "/home/clawdbot/clawd/skills/aeo-monitor/logs", "description": "Where monitor.py writes jsonl/csv logs."},
      "pythonPath": {"type": "string", "default": "python3", "description": "Python executable to run monitor.py"},
      "scriptPath": {"type": "string", "default": "/home/clawdbot/clawd/skills/aeo-monitor/monitor.py", "description": "Path to the AEO monitor script"},

      "openaiApiKey": {"type": "string", "secret": true, "description": "OPENAI_API_KEY for ChatGPT query tier"},
      "geminiApiKey": {"type": "string", "secret": true, "description": "GEMINI_API_KEY for Gemini query tier"},

      "slackBotToken": {"type": "string", "secret": true, "description": "Slack bot token (xoxb-...)"},
      "slackChannelId": {"type": "string", "default": "C0ABW156NKX", "description": "Slack channel ID to post scorecard (default: #nomie-marketing)"},

      "postEvenIfNoKeys": {"type": "boolean", "default": false, "description": "If true, posts an error scorecard when no model keys configured."}
    }
  }
}
